rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: businesses
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - description: string (optional, 0-500 chars)
    //   - ownerUid: string (required, matches auth.uid)
    //   - createdAt: timestamp (required)
    //
    // Collection: transactions
    // Fields:
    //   - businessId: string (required, must exist in businesses)
    //   - type: string (required, 'income' or 'expense')
    //   - amount: number (required, positive)
    //   - category: string (required, 1-50 chars)
    //   - description: string (optional, 0-500 chars)
    //   - date: timestamp (required)
    //   - ownerUid: string (required, matches auth.uid)
    //
    // Collection: categories
    // Fields:
    //   - name: string (required, 1-50 chars)
    //   - type: string (required, 'income' or 'expense')
    //   - ownerUid: string (required, matches auth.uid)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getRole(businessId) {
      return exists(/databases/$(database)/documents/userRoles/$(request.auth.uid + "_" + businessId)) 
        ? get(/databases/$(database)/documents/userRoles/$(request.auth.uid + "_" + businessId)).data.role 
        : null;
    }

    function hasRole(businessId, role) {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/businesses/$(businessId)) && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerUid == request.auth.uid) ||
        (exists(/databases/$(database)/documents/userRoles/$(request.auth.uid + "_" + businessId)) && get(/databases/$(database)/documents/userRoles/$(request.auth.uid + "_" + businessId)).data.role == role)
      );
    }

    function isSuperAdmin(businessId) {
      return isAdmin() || hasRole(businessId, 'superadmin');
    }

    function isManager(businessId) {
      return isAdmin() || hasRole(businessId, 'manager') || isSuperAdmin(businessId);
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.uid == "muhzsLfYo5bbCxxAEcicWK0HmQs1" ||
        request.auth.token.email.lower() == "m.khoirulirsyad@gmail.com"
      );
    }

    function uidNotModified() {
      return !('ownerUid' in request.resource.data) || request.resource.data.ownerUid == resource.data.ownerUid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // Domain Validators
    function isValidBusiness(data) {
      return hasRequiredFields(['name', 'ownerUid', 'createdAt']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.ownerUid == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidTransaction(data) {
      return hasRequiredFields(['businessId', 'type', 'amount', 'category', 'date', 'ownerUid']) &&
             data.businessId is string &&
             data.type in ['income', 'expense'] &&
             data.amount is number && data.amount > 0 &&
             data.category is string && data.category.size() >= 1 && data.category.size() <= 50 &&
             data.date is timestamp &&
             data.ownerUid == request.auth.uid;
    }

    function isValidEmployee(data) {
      return hasRequiredFields(['businessId', 'name', 'ownerUid']) &&
             data.businessId is string &&
             data.name is string && data.name.size() >= 1 &&
             data.ownerUid == request.auth.uid;
    }

    function isValidAttendance(data) {
      return hasRequiredFields(['employeeId', 'businessId', 'date', 'status', 'ownerUid']) &&
             data.employeeId is string &&
             data.businessId is string &&
             data.date is string &&
             data.status in ['present', 'absent', 'late', 'leave'] &&
             data.ownerUid == request.auth.uid;
    }

    // Match Rules
    match /businesses/{businessId} {
      // Allow all authenticated users to read for client-side filtering
      // In production, harden this to only allow owners/managers
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBusiness(request.resource.data);
      allow update: if isSuperAdmin(businessId) && isValidBusiness(request.resource.data) && uidNotModified();
      allow delete: if isSuperAdmin(businessId);
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isManager(request.resource.data.businessId) && isValidTransaction(request.resource.data);
      allow update: if isAuthenticated() && isManager(resource.data.businessId) && isValidTransaction(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && isSuperAdmin(resource.data.businessId);
    }

    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isManager(request.resource.data.businessId) && isValidEmployee(request.resource.data);
      allow update: if isAuthenticated() && isManager(resource.data.businessId) && isValidEmployee(request.resource.data);
      allow delete: if isAuthenticated() && isSuperAdmin(resource.data.businessId);
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isManager(request.resource.data.businessId) && isValidAttendance(request.resource.data);
      allow update: if isAuthenticated() && isManager(resource.data.businessId) && isValidAttendance(request.resource.data);
      allow delete: if isAuthenticated() && isSuperAdmin(resource.data.businessId);
    }

    match /userRoles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isSuperAdmin(request.resource.data.businessId);
    }

    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /test/connection {
      allow read: if true;
    }

    match /appSettings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
